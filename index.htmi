<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>จองคิว - ร้านอร่อยจัง</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-100 font-sans min-h-screen flex flex-col justify-between">

    <header class="bg-amber-500 text-white shadow-md p-4 text-center">
        <h1 class="text-2xl font-bold"><i class="fa-solid fa-utensils mr-2"></i>ร้านอาหาร "อร่อยจัง"</h1>
        <p class="text-sm opacity-90 mt-1">ยินดีต้อนรับกรุณากรอกข้อมูลเพื่อจองคิว</p>
    </header>

    <main class="max-w-md mx-auto px-4 py-6 w-full flex-1">
        <section class="bg-white p-6 rounded-2xl shadow-sm border border-gray-200">
            <h2 class="text-xl font-bold text-gray-800 mb-4 flex items-center">
                <span class="bg-amber-100 text-amber-600 p-2 rounded-lg mr-2"><i class="fa-solid fa-user-plus"></i></span>
                กรอกข้อมูลจองคิว
            </h2>
            
            <form id="queueForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">ชื่อผู้จอง</label>
                    <input type="text" id="customerName" required placeholder="เช่น คุณสมชาย" class="w-full px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-500 focus:outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">เบอร์โทรศัพท์</label>
                    <input type="tel" id="customerPhone" required placeholder="เช่น 081-234-5678" class="w-full px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-500 focus:outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">จำนวนที่นั่ง (ท่าน)</label>
                    <input type="number" id="customerSeats" min="1" max="20" required placeholder="เช่น 4" class="w-full px-4 py-2 border border-gray-300 rounded-xl focus:ring-2 focus:ring-amber-500 focus:outline-none">
                </div>
                <button type="submit" class="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-3 px-4 rounded-xl transition shadow-md">
                    กดจองคิวเลย
                </button>
            </form>

            <div id="successCard" class="mt-6 p-4 bg-green-50 border border-green-200 rounded-xl hidden">
                <div class="text-center">
                    <i class="fa-solid fa-circle-check text-green-500 text-3xl mb-2"></i>
                    <h3 class="font-bold text-green-800 text-lg">จองคิวสำเร็จ!</h3>
                    <p class="text-gray-600 text-sm mt-1">คิวของคุณคือหมายเลข</p>
                    <div id="ticketNumber" class="text-4xl font-extrabold text-amber-600 my-2">กำลังรันคิว...</div>
                    <p id="ticketInfo" class="text-xs text-gray-500"></p>
                </div>
            </div>
        </section>
    </main>

    <footer class="text-center py-4 text-xs text-gray-400">© 2026 ร้านอร่อยจัง ระบบคิวออนไลน์</footer>

    <script>
        // ⚠️ สำคัญมาก: เอาลิงก์ที่ก๊อปปี้มาจาก Firebase ขั้นตอนที่ 5 มาวางแทนที่เครื่องหมายคำพูดด้านล่างนี้ครับ
        const FIREBASE_URL = "ใส่ลิงก์ฐานข้อมูลของคุณตรงนี้ เช่น https://xxx.firebaseio.com/";

        document.getElementById('queueForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const name = document.getElementById('customerName').value;
            const phone = document.getElementById('customerPhone').value;
            const seats = document.getElementById('customerSeats').value;

            document.getElementById('successCard').classList.remove('hidden');
            document.getElementById('ticketNumber').textContent = "กำลังจอง...";

            try {
                // ดึงข้อมูลคิวล่าสุดจาก Firebase เพื่อหาเลขคิวถัดไป
                const res = await fetch(`${FIREBASE_URL}/currentNumber.json`);
                let currentNum = await res.json() || 0;
                let nextNum = currentNum + 1;
                const qCode = `Q-${String(nextNum).padStart(2, '0')}`;

                const newCustomer = {
                    code: qCode,
                    name: name,
                    phone: phone,
                    seats: seats,
                    timestamp: Date.now()
                };

                // ส่งข้อมูลเข้าฐานข้อมูล
                await fetch(`${FIREBASE_URL}/queues.json`, {
                    method: 'POST',
                    body: JSON.stringify(newCustomer)
                });

                // อัปเดตเลขคิวล่าสุดในระบบ
                await fetch(`${FIREBASE_URL}/currentNumber.json`, {
                    method: 'PUT',
                    body: JSON.stringify(nextNum)
                });

                document.getElementById('ticketNumber').textContent = qCode;
                document.getElementById('ticketInfo').textContent = `คุณ ${name} (${seats} ที่นั่ง)`;
                document.getElementById('queueForm').reset();

            } catch (error) {
                alert('เกิดข้อผิดพลาด กรุณาลองใหม่');
                console.error(error);
            }
        });
    </script>
</body>
</html>
